deployment:
  replicas: 1

updateStrategy:
  type: Recreate

service:
  enabled: false

ingressClass:
  enabled: true
  isDefaultClass: true

ports:
  web:
    hostPort: 80
    http:
      redirections:
        entryPoint:
          to: websecure
          scheme: https
          permanent: true
  websecure:
    hostPort: 443

providers:
  kubernetesIngress:
    allowExternalNameServices: true
    ingressEndpoint:
      ip: "{{ public_ip | default(ansible_host) }}"
  kubernetesCRD:
    allowExternalNameServices: true
